    .p-card:hover{transform:translateY(-3px);border-color:var(--beige)}
    .p-card .pimg{aspect-ratio:1/1;background:var(--soft);position:relative;overflow:hidden}
    .p-card .pimg img{width:100%;height:100%;object-fit:cover;transition:.5s}
    .p-card:hover .pimg img{transform:scale(1.04)}
    .p-card .jbadge{position:absolute;top:14px;left:14px;background:rgba(255,255,255,.94);padding:4px 8px;font-size:8px;letter-spacing:1.6px;text-transform:uppercase;font-weight:500;color:var(--ok);display:flex;align-items:center;gap:6px}
    .p-card .jbadge::before{content:"";width:5px;height:5px;background:var(--ok);border-radius:50%}
