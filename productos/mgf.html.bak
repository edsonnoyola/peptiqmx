    .product-visual img{width:86%;height:86%;object-fit:contain}
    .product-visual::after{content:"LOT · PTQ-BPC-0421";position:absolute;bottom:18px;left:18px;font-size:9px;letter-spacing:2.4px;color:var(--mute);font-weight:500}
