    .dose{padding:96px 0;background:var(--stone)}
    .dose-inner{max-width:820px;margin:0 auto}
    .dose .eyebrow{display:block;margin-bottom:16px}
    .dose h2{font-family:var(--serif);font-size:clamp(30px,4vw,46px);font-weight:400;line-height:1.1;margin-bottom:32px;letter-spacing:-.01em}
    .dose h2 em{font-style:italic;color:var(--beige-deep)}
    .dtable{background:var(--paper);border:1px solid var(--rule)}
    .dtable .drow{display:grid;grid-template-columns:220px 1fr;gap:24px;padding:20px 28px;border-bottom:1px solid var(--rule)}
    .dtable .drow:last-child{border-bottom:0}
    .dtable .dk{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--mute);font-weight:500;align-self:center}
    .dtable .dv{font-family:var(--serif);font-size:18px;font-weight:500}
    .dtable .dv small{font-size:13px;color:var(--mute);font-family:var(--sans);font-weight:400;margin-left:6px}
    .dfine{margin-top:20px;font-size:12px;color:var(--mute);font-style:italic;line-height:1.6}
    @media(max-width:720px){.dtable .drow{grid-template-columns:1fr;gap:4px}}
    .coa{padding:120px 0;background:var(--ink);color:var(--paper)}
    .coa-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
    .coa-body .eyebrow{color:var(--gold);display:block;margin-bottom:20px}
    .coa-body h2{font-family:var(--serif);font-size:clamp(30px,4vw,48px);font-weight:400;line-height:1.1;margin-bottom:24px}
    .coa-body h2 em{font-style:italic;color:var(--gold)}
    .coa-body p{color:#c8c1b2;font-size:15px;margin-bottom:32px;max-width:420px;line-height:1.7}
    .coa-panel{background:rgba(255,255,255,.03);border:1px solid rgba(198,169,105,.3);padding:32px;font-family:'SF Mono', Menlo, monospace}
    .coa-row{display:grid;grid-template-columns:120px 1fr;gap:18px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:12px}
    .coa-row:last-child{border-bottom:0}
    .coa-row .k{color:#8a8274;letter-spacing:1.6px;text-transform:uppercase;font-size:10px;font-weight:500;align-self:center}
