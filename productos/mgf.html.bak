    @media(max-width:960px){.phero-grid{grid-template-columns:1fr;gap:40px}.pstats{gap:12px}}
    .mech{padding:96px 0;background:var(--paper);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule)}
    .mech-inner{max-width:820px;margin:0 auto}
    .mech .eyebrow{display:block;margin-bottom:16px}
    .mech h2{font-family:var(--serif);font-size:clamp(30px,4vw,46px);font-weight:400;line-height:1.1;margin-bottom:32px;letter-spacing:-.01em}
