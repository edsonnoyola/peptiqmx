  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{--ink:#111111;--stone:#F6F3EE;--paper:#FFFFFF;--beige:#B8A99A;--beige-deep:#9C8D7F;--gold:#C6A969;--rule:#E3DED6;--mute:#6B6B6B;--soft:#F0ECE4;--ok:#22C55E;--serif:'Playfair Display', Georgia, serif;--sans:'Inter', -apple-system, sans-serif}
